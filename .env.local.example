# =============================================================================
# KEYRA — .env.local.example (template público, COMMITÁVEL)
# =============================================================================
# Copie para .env.local e preencha com valores reais (ou use ./scripts/sync-env.sh
# para gerar a partir de .keyra-secrets/)
# =============================================================================

# ---- Supabase (cliente) ----
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ---- Supabase (servidor) ----
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PROJECT_REF=<project-ref>

# ---- Supabase CLI ----
SUPABASE_ACCESS_TOKEN=sbp_...

# ---- Vercel ----
VERCEL_TOKEN=vcp_...

# ---- GitHub ----
GH_TOKEN=ghp_...
GITHUB_TOKEN=ghp_...
