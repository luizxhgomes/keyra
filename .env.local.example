# =============================================================================
# KEYRA — .env.local.example (template público, COMMITÁVEL)
# =============================================================================
# Copie para .env.local e preencha com valores reais (ou use ./scripts/sync-env.sh
# para gerar a partir de .keyra-secrets/)
# =============================================================================

# ---- Supabase (cliente) ----
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ---- Supabase (servidor) ----
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PROJECT_REF=<project-ref>

# ---- Supabase CLI ----
SUPABASE_ACCESS_TOKEN=sbp_...

# ---- Application secrets ----
COLUMN_ENCRYPTION_KEY=<64 hex chars from openssl rand -hex 32>

# ---- Email transacional (ADR-021: Resend) ----
# Gere em https://resend.com/api-keys. Domain `keyra.app` precisa estar verificado
# (SPF + DKIM + DMARC no Cloudflare) antes de enviar para endereços externos.
# Sem RESEND_API_KEY, o helper `sendEmail` faz dry-run (console.log apenas).
RESEND_API_KEY=re_...
EMAIL_FROM="KEYRA <no-reply@keyra.app>"

# ---- Vercel ----
VERCEL_TOKEN=vcp_...

# ---- GitHub ----
GH_TOKEN=ghp_...
GITHUB_TOKEN=ghp_...

# ---- CAPTCHA (ADR-022 / Story auth.0) ----
# Cloudflare Turnstile — gratuito ilimitado.
# Como obter:
#   1. Acesse https://dash.cloudflare.com/?to=/:account/turnstile
#   2. Crie um novo widget (modo "Managed" para invisível na maioria dos casos)
#   3. Copie a "Site Key" (pública) e a "Secret Key" (privada)
# A site key vai pro bundle do cliente (pública); a secret key fica server-only.
# Sem essas vars, o helper `verify-turnstile.ts` faz bypass em dev e falha em prod.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
