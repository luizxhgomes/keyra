{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "KEYRA Design Tokens — DTCG format. Source of truth for brand and product layers. Generated 2026-05-07 from 12 reference images by Brand Chief.",
  "$metadata": {
    "version": "1.0.0",
    "name": "KEYRA Design Tokens",
    "lastUpdated": "2026-05-07",
    "owner": "@michael-johnson via brand-chief",
    "culturalDirection": "Editorial Beauty Luxury"
  },

  "color": {
    "$description": "Core color palette. All warm. Zero blue. Zero pink-baby. Zero cyan.",

    "ivory": {
      "50":  { "$value": "#FAF6EE", "$type": "color", "$description": "Background base — substitui white em toda peça" },
      "100": { "$value": "#F4EDE2", "$type": "color", "$description": "Surface elevada" }
    },
    "sand": {
      "200": { "$value": "#EAE0CF", "$type": "color", "$description": "Border subtle, divider, skeleton" }
    },
    "mocha": {
      "300": { "$value": "#C8B49A", "$type": "color", "$description": "Border default, placeholder, muted form" }
    },
    "bronze": {
      "400": { "$value": "#946640", "$type": "color", "$description": "Foreground muted, ícone secundário" },
      "500": { "$value": "#7E5A40", "$type": "color", "$description": "Foreground secondary, accent warm sutil" }
    },
    "cocoa": {
      "700": { "$value": "#5A3E26", "$type": "color", "$description": "Foreground emphasis, label forte" },
      "800": { "$value": "#3F2A1B", "$type": "color", "$description": "Heading body, contraste forte" },
      "900": { "$value": "#2B1810", "$type": "color", "$description": "Foreground primary — substitui black" }
    },
    "ink": {
      "950": { "$value": "#181210", "$type": "color", "$description": "Background brand premium dark, máximo escuro" }
    },

    "amber": {
      "300": { "$value": "#E5B473", "$type": "color" },
      "400": { "$value": "#D89A4D", "$type": "color" },
      "500": { "$value": "#C8843A", "$type": "color", "$description": "Acento padrão e warning" }
    },
    "terracotta": {
      "500": { "$value": "#C26832", "$type": "color" },
      "600": { "$value": "#B8612B", "$type": "color", "$description": "CTA primário brand" },
      "700": { "$value": "#A05525", "$type": "color", "$description": "CTA active/pressed" }
    },
    "rust": {
      "800": { "$value": "#843E1A", "$type": "color", "$description": "Erro forte, destrutivo" }
    },

    "champagne": {
      "200": { "$value": "#F0D8A8", "$type": "color", "$description": "Highlight texto em fundo cocoa" }
    },
    "gold": {
      "300": { "$value": "#E5C690", "$type": "color" },
      "400": { "$value": "#D4A752", "$type": "color" },
      "500": { "$value": "#B8923A", "$type": "color", "$description": "Brand accent canônico — uso raro/precioso" },
      "600": { "$value": "#9A7A2C", "$type": "color" }
    },

    "success": {
      "leaf": { "$value": "#6E8C5A", "$type": "color", "$description": "Verde-oliva contido — não verde neon" },
      "deep": { "$value": "#4F6840", "$type": "color" }
    },
    "info": {
      "default": { "$value": "#5A6C7E", "$type": "color", "$description": "Cinza azulado quente, uso raríssimo" }
    },

    "pure": {
      "white": { "$value": "#FFFFFF", "$type": "color", "$description": "Texto sobre fundo cocoa-900" },
      "black": { "$value": "#000000", "$type": "color", "$description": "Evitar — usar cocoa-900 ou ink-950" }
    }
  },

  "semantic": {
    "$description": "Semantic mapping for product and brand contexts.",

    "brand": {
      "background": { "$value": "{color.ivory.50}", "$type": "color" },
      "background-dark": { "$value": "{color.cocoa.900}", "$type": "color" },
      "background-darkest": { "$value": "{color.ink.950}", "$type": "color" },
      "foreground-on-light": { "$value": "{color.cocoa.900}", "$type": "color" },
      "foreground-on-dark": { "$value": "{color.champagne.200}", "$type": "color" },
      "cta-primary": { "$value": "{color.terracotta.600}", "$type": "color" },
      "cta-primary-hover": { "$value": "{color.terracotta.700}", "$type": "color" },
      "premium-accent": { "$value": "{color.gold.500}", "$type": "color" },
      "border-decorative": { "$value": "{color.mocha.300}", "$type": "color" }
    },

    "product": {
      "background": { "$value": "{color.ivory.50}", "$type": "color" },
      "surface": { "$value": "{color.pure.white}", "$type": "color" },
      "surface-muted": { "$value": "{color.ivory.100}", "$type": "color" },
      "foreground": { "$value": "{color.cocoa.900}", "$type": "color" },
      "foreground-secondary": { "$value": "{color.bronze.500}", "$type": "color" },
      "foreground-muted": { "$value": "{color.bronze.400}", "$type": "color" },
      "border-subtle": { "$value": "{color.sand.200}", "$type": "color" },
      "border-default": { "$value": "{color.mocha.300}", "$type": "color" },
      "accent": { "$value": "{color.bronze.500}", "$type": "color" },
      "accent-hover": { "$value": "{color.cocoa.700}", "$type": "color" },
      "cta-primary": { "$value": "{color.terracotta.600}", "$type": "color" },
      "cta-primary-hover": { "$value": "{color.terracotta.700}", "$type": "color" },
      "cta-primary-foreground": { "$value": "{color.ivory.50}", "$type": "color" },
      "premium-accent": { "$value": "{color.gold.500}", "$type": "color" },
      "success": { "$value": "{color.success.leaf}", "$type": "color" },
      "success-strong": { "$value": "{color.success.deep}", "$type": "color" },
      "warning": { "$value": "{color.amber.500}", "$type": "color" },
      "destructive": { "$value": "{color.rust.800}", "$type": "color" },
      "info": { "$value": "{color.info.default}", "$type": "color" }
    }
  },

  "fontFamily": {
    "serif": {
      "$value": "Fraunces, Times New Roman, serif",
      "$type": "fontFamily",
      "$description": "Editorial display — Fraunces (Google Fonts, OFL)"
    },
    "sans": {
      "$value": "Inter, -apple-system, Segoe UI, sans-serif",
      "$type": "fontFamily",
      "$description": "Functional sans — Inter (Google Fonts, OFL)"
    },
    "mono": {
      "$value": "ui-monospace, Menlo, monospace",
      "$type": "fontFamily"
    }
  },

  "fontWeight": {
    "thin":       { "$value": 200, "$type": "fontWeight" },
    "light":      { "$value": 300, "$type": "fontWeight" },
    "regular":    { "$value": 400, "$type": "fontWeight" },
    "medium":     { "$value": 500, "$type": "fontWeight" },
    "semibold":   { "$value": 600, "$type": "fontWeight" },
    "bold":       { "$value": 700, "$type": "fontWeight" }
  },

  "fontSize": {
    "$description": "Base 16px. Brand layer = expressive. Product layer = functional.",

    "brand-hero":         { "$value": "clamp(64px, 10vw, 144px)", "$type": "dimension" },
    "brand-display-1":    { "$value": "clamp(48px, 6vw, 96px)", "$type": "dimension" },
    "brand-display-2":    { "$value": "clamp(36px, 4.5vw, 64px)", "$type": "dimension" },
    "brand-headline":     { "$value": "32px", "$type": "dimension" },
    "brand-subhead":      { "$value": "24px", "$type": "dimension" },
    "brand-body-large":   { "$value": "20px", "$type": "dimension" },
    "brand-body":         { "$value": "17px", "$type": "dimension" },
    "brand-caption":      { "$value": "14px", "$type": "dimension" },
    "brand-overline":     { "$value": "12px", "$type": "dimension" },

    "ui-page-title":           { "$value": "32px", "$type": "dimension" },
    "ui-section-title":        { "$value": "24px", "$type": "dimension" },
    "ui-card-title":           { "$value": "18px", "$type": "dimension" },
    "ui-kpi-value":            { "$value": "clamp(40px, 5vw, 64px)", "$type": "dimension" },
    "ui-kpi-value-secondary":  { "$value": "24px", "$type": "dimension" },
    "ui-kpi-label":            { "$value": "13px", "$type": "dimension" },
    "ui-body":                 { "$value": "15px", "$type": "dimension" },
    "ui-label":                { "$value": "14px", "$type": "dimension" },
    "ui-caption":              { "$value": "13px", "$type": "dimension" },
    "ui-micro":                { "$value": "12px", "$type": "dimension" }
  },

  "lineHeight": {
    "tight":  { "$value": "1.0",  "$type": "number" },
    "snug":   { "$value": "1.15", "$type": "number" },
    "normal": { "$value": "1.4",  "$type": "number" },
    "relaxed":{ "$value": "1.55", "$type": "number" },
    "loose":  { "$value": "1.7",  "$type": "number" }
  },

  "letterSpacing": {
    "tight":   { "$value": "-0.02em", "$type": "string" },
    "snug":    { "$value": "-0.01em", "$type": "string" },
    "normal":  { "$value": "0",       "$type": "string" },
    "wide":    { "$value": "0.04em",  "$type": "string" },
    "extra":   { "$value": "0.12em",  "$type": "string" }
  },

  "spacing": {
    "$description": "Roomy density inherited from docs/ux/spacing-tokens.md.",
    "0":  { "$value": "0",     "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "5":  { "$value": "20px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "16": { "$value": "64px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "96px",  "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },

  "borderRadius": {
    "$description": "Subtle. Editorial. Não pode ser muito redondo — perde gravitas.",
    "none":  { "$value": "0",      "$type": "dimension" },
    "xs":    { "$value": "2px",    "$type": "dimension" },
    "sm":    { "$value": "4px",    "$type": "dimension" },
    "md":    { "$value": "8px",    "$type": "dimension" },
    "lg":    { "$value": "12px",   "$type": "dimension" },
    "xl":    { "$value": "16px",   "$type": "dimension" },
    "full":  { "$value": "9999px", "$type": "dimension", "$description": "Pills, avatars" }
  },

  "shadow": {
    "$description": "Warm shadows — based on cocoa, not slate.",
    "xs": {
      "$value": { "color": "rgba(43, 24, 16, 0.04)", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0" },
      "$type": "shadow"
    },
    "sm": {
      "$value": { "color": "rgba(43, 24, 16, 0.06)", "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "0" },
      "$type": "shadow"
    },
    "md": {
      "$value": { "color": "rgba(43, 24, 16, 0.08)", "offsetX": "0px", "offsetY": "4px", "blur": "8px", "spread": "0" },
      "$type": "shadow"
    },
    "lg": {
      "$value": { "color": "rgba(43, 24, 16, 0.12)", "offsetX": "0px", "offsetY": "8px", "blur": "16px", "spread": "0" },
      "$type": "shadow"
    },
    "xl": {
      "$value": { "color": "rgba(43, 24, 16, 0.16)", "offsetX": "0px", "offsetY": "16px", "blur": "32px", "spread": "0" },
      "$type": "shadow"
    },
    "premium-glow": {
      "$value": { "color": "rgba(184, 146, 58, 0.18)", "offsetX": "0px", "offsetY": "0px", "blur": "24px", "spread": "0" },
      "$type": "shadow",
      "$description": "Gold glow — uso raro em badge/elemento premium"
    }
  },

  "motion": {
    "$description": "Motion tokens. Documentação humana em motion-system/motion-tokens.md.",
    "duration": {
      "instant":   { "$value": "100ms", "$type": "duration", "$description": "Hover, focus, press" },
      "fast":      { "$value": "200ms", "$type": "duration", "$description": "Toggle, micro-feedback, dismiss" },
      "base":      { "$value": "320ms", "$type": "duration", "$description": "DEFAULT — reveal, transição padrão" },
      "slow":      { "$value": "480ms", "$type": "duration", "$description": "Reveal narrativo, modal entry" },
      "cinematic": { "$value": "720ms", "$type": "duration", "$description": "Hero brand, drama editorial" }
    },
    "easing": {
      "out-soft":           { "$value": "cubic-bezier(0.22, 1, 0.36, 1)",   "$type": "cubicBezier", "$description": "DEFAULT — toda entrada" },
      "in-out-editorial":   { "$value": "cubic-bezier(0.65, 0, 0.35, 1)",   "$type": "cubicBezier", "$description": "Page transition, modal" },
      "in-quiet":           { "$value": "cubic-bezier(0.7, 0, 0.84, 0)",    "$type": "cubicBezier", "$description": "Saída, dismiss" },
      "out-bounce-subtle":  { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)","$type": "cubicBezier", "$description": "Sucesso premium — uso raro" }
    },
    "distance": {
      "whisper":   { "$value": "4px",  "$type": "dimension", "$description": "Toast dismiss, hover sutil" },
      "small":     { "$value": "8px",  "$type": "dimension", "$description": "Fade-up default" },
      "medium":    { "$value": "16px", "$type": "dimension", "$description": "Modal/drawer entry" },
      "large":     { "$value": "32px", "$type": "dimension", "$description": "Page slide" },
      "dramatic":  { "$value": "64px", "$type": "dimension", "$description": "Hero brand layer reveal" }
    },
    "stagger": {
      "tight":   { "$value": "40ms",  "$type": "duration", "$description": "Lista densa (≥10 itens)" },
      "small":   { "$value": "80ms",  "$type": "duration", "$description": "Lista padrão (3-7)" },
      "medium":  { "$value": "120ms", "$type": "duration", "$description": "Reveal narrativo KPI" },
      "large":   { "$value": "160ms", "$type": "duration", "$description": "Drama brand layer" }
    },
    "scale": {
      "quiet":      { "$value": "0.98", "$type": "number", "$description": "Hover sutil" },
      "default":    { "$value": "0.96", "$type": "number", "$description": "Modal entry, card reveal" },
      "pronounced": { "$value": "0.92", "$type": "number", "$description": "Drama editorial — raro" }
    }
  }
}
